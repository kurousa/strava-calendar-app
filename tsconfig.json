{
    "compilerOptions": {
        "target": "ES2019",
        "lib": [
            "ES2019"
        ],
        "module": "CommonJS",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "google-apps-script",
            "node"
        ],
        "noEmit": true
    },
    "include": [
        "*.ts",
        "formatters/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "tests/**",
        "vitest.config.ts",
        "vitest.setup.ts"
    ]
}