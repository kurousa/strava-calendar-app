{
    "compilerOptions": {
        "target": "ES2019",
        "lib": [
            "ES2019"
        ],
        "module": "CommonJS",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "declaration": false,
        "removeComments": false,
        "isolatedModules": true,
        "types": [
            "google-apps-script",
            "node"
        ]
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dashboard",
        "tests/**",
        "vitest.config.ts",
        "vitest.setup.ts"
    ]
}
