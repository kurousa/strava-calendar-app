{
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc --project tsconfig.build.json && cp appsscript.json index.html dist/",
    "push": "npm run build && npx @google/clasp push"
  }
}