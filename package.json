{
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "shx": "^0.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "shx rm -rf dist",
    "build": "pnpm run clean && tsc && shx cp appsscript.json index.html dist/",
    "push:dev": "pnpm run build && shx cp .clasp-dev.json .clasp.json && clasp push",
    "push:prod": "pnpm run build && shx cp .clasp-prod.json .clasp.json && clasp push",
    "open:dev": "shx cp .clasp-dev.json .clasp.json && clasp open",
    "open:prod": "shx cp .clasp-prod.json .clasp.json && clasp open",
    "pull:dev": "shx cp .clasp-dev.json .clasp.json && clasp pull",
    "pull:prod": "shx cp .clasp-prod.json .clasp.json && clasp pull"
  }
}
